# Database
# Replace with your actual PostgreSQL database URL
DATABASE_URL="postgresql://username:password@localhost:5432/your_database_name"

# NextAuth.js
# For local development
NEXTAUTH_URL="http://localhost:3000"
# For production, set this to your actual domain:
# NEXTAUTH_URL="https://your-production-domain.com"
NEXTAUTH_SECRET="your-nextauth-secret-key-here-generate-a-random-string"

# Email Configuration 
# Configure your SMTP settings (Gmail example shown)
EMAIL_SMTP_HOST="smtp.gmail.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER="your-email@gmail.com"
EMAIL_SMTP_PASSWORD="your-app-password-here"
EMAIL_FROM="your-email@gmail.com"

# Email Bulk Sending Configuration
EMAIL_BATCH_SIZE="10"        # Number of emails to send per batch (default: 10, max: 50)
EMAIL_BATCH_DELAY_MS="1000"  # Delay between batches in milliseconds (default: 1000ms, min: 100ms)

# Domain Configuration
# Set your organization's email domain for user registration
ALLOWED_EMAIL_DOMAIN="yourcompany.com"

# File Upload
MAX_FILE_SIZE="5242880" # 5MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp"

# Rate Limiting
RATE_LIMIT_POSTS_PER_HOUR="10"
RATE_LIMIT_COMMENTS_PER_HOUR="30"

# Security
CSRF_SECRET="your-csrf-secret-generate-random-string"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
ENABLE_CRON=false

# Cloudinary Configuration
# Sign up at https://cloudinary.com and get your credentials
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Timezone Configuration
# Set your preferred timezone (see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
ADMIN_TIMEZONE="Asia/Karachi"
DEFAULT_USER_TIMEZONE="Asia/Karachi"

# Development SSL Fix (only for local development)
# Set to 0 only if you encounter SSL certificate issues in development
NODE_TLS_REJECT_UNAUTHORIZED=0
